{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Blog": {
      "title": "Blog",
      "description": "A connected Blogger blog",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Blogger Blog ID" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url", "ownerUid", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "A generated article",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "blogId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "status", "ownerUid", "createdAt"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "A user support ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "subject", "message", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User specific settings and OAuth tokens",
      "type": "object",
      "properties": {
        "bloggerTokens": {
          "type": "object",
          "properties": {
            "access_token": { "type": "string" },
            "refresh_token": { "type": "string" },
            "expiry_date": { "type": "number" }
          }
        },
        "defaultKeywords": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/blogs/{blogId}": {
      "schema": { "$ref": "#/entities/Blog" },
      "description": "Connected Blogger blogs"
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Generated articles"
    },
    "/settings/{userId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "User settings and tokens"
    },
    "/support_tickets/{ticketId}": {
      "schema": { "$ref": "#/entities/SupportTicket" },
      "description": "User support tickets"
    }
  }
}
