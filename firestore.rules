rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (('email' in request.auth.token && (request.auth.token.email == "av6ora@gmail.com" || request.auth.token.email == "contact@avbora.online") && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isDocOwner() {
      return isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    function uidUnchanged() {
      return request.resource.data.ownerUid == request.auth.uid;
    }

    function uidNotModified() {
      return request.resource.data.ownerUid == resource.data.ownerUid;
    }

    // Validation Functions
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             (!('firstName' in data) || data.firstName is string) &&
             (!('lastName' in data) || data.lastName is string) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('plan' in data) || data.plan is string);
    }

    function isValidBlog(data) {
      return data.ownerUid is string &&
             data.id is string &&
             data.title is string &&
             data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.size() < 500 &&
             (!('topic' in data) || data.topic is string) &&
             (!('language' in data) || data.language is string) &&
             (!('prompts' in data) || data.prompts is string) &&
             (!('autoPost' in data) || data.autoPost is bool) &&
             (!('postFrequency' in data) || data.postFrequency is number) &&
             (!('lastAutoPostAt' in data) || data.lastAutoPostAt is timestamp || data.lastAutoPostAt == null);
    }

    function isValidArticle(data) {
      return data.ownerUid is string &&
             data.blogId is string &&
             data.title is string &&
             data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 100000 &&
             data.status in ['draft', 'scheduled', 'published'];
    }

    function isValidSupportTicket(data) {
      return data.ownerUid is string &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.status in ['open', 'in_progress', 'closed'] &&
             (!('email' in data) || data.email is string);
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidBlog(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidBlog(request.resource.data) && ((isDocOwner() && uidNotModified()) || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidArticle(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidArticle(request.resource.data) && ((isDocOwner() && uidNotModified()) || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    // Settings
    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSupportTicket(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidSupportTicket(request.resource.data) && ((isDocOwner() && uidNotModified()) || isAdmin());
      allow delete: if isAdmin();
    }

    // Connection test
    match /test/connection {
      allow read: if true;
    }

    match /health_check/{docId} {
      allow read: if true;
    }
  }
}
