rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (('email' in request.auth.token && request.auth.token.email == "av6ora@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isDocOwner() {
      return isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    // Validation Functions
    function isValidBlog(data) {
      return data.ownerUid == request.auth.uid &&
             data.id is string &&
             data.title is string &&
             data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.size() < 500 &&
             (!('topic' in data) || data.topic is string) &&
             (!('language' in data) || data.language is string) &&
             (!('prompts' in data) || data.prompts is string) &&
             (!('autoPost' in data) || data.autoPost is bool) &&
             (!('postFrequency' in data) || data.postFrequency is number) &&
             (!('lastAutoPostAt' in data) || data.lastAutoPostAt is timestamp || data.lastAutoPostAt == null);
    }

    function isValidArticle(data) {
      return data.ownerUid == request.auth.uid &&
             data.blogId is string &&
             data.title is string &&
             data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 100000 &&
             data.status in ['draft', 'scheduled', 'published'];
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBlog(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidBlog(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidArticle(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidArticle(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    // Settings
    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Connection test
    match /test/connection {
      allow read: if true;
    }

    match /health_check/{docId} {
      allow read: if true;
    }
  }
}
